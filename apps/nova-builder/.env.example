# Nova Builder — environment variables reference
#
# Copy to `.env.local` for local dev / e2e (this file and .env.local are the ONLY
# place local secrets live; .env.local is gitignored and NEVER reaches Cloudflare).
#
# ─────────────────────────────────────────────────────────────────────────────
# TWO CLASSES OF VARS — they are configured in DIFFERENT places on Cloudflare:
#
#   [BUILD]   NEXT_PUBLIC_* — inlined into the client bundle at BUILD time.
#             Set them in the Cloudflare Dashboard →
#             Workers & Pages → nova-editor → Settings → Build → Variables
#             (Build scope). `wrangler secret` does NOT work for these.
#
#   [RUNTIME] server-side secrets — read by the Worker at request time.
#             Push them fast with:  node scripts/cf-push-secrets.mjs
#             (wraps `wrangler secret bulk`; skips NEXT_PUBLIC_* automatically).
# ─────────────────────────────────────────────────────────────────────────────

# ── [BUILD] Public / client-inlined ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_ASSET_BASE_URL=          # R2 public bucket base URL (canvas assets)
NEXT_PUBLIC_APP_HOST=                # canonical app host (custom-domain routing)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_MAX_FREE_CREDITS=200

# ── [RUNTIME] Supabase (server) ──────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── [RUNTIME] Auth (NextAuth) ────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=                        # e.g. https://nova-editor.<acct>.workers.dev
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── [RUNTIME] AI providers (packages/ai — used by /api/ai) ───────────────────
AI_PROVIDER=anthropic                # default provider
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# ── [RUNTIME] Crypto / cron ──────────────────────────────────────────────────
ENCRYPTION_KEY=                      # AES key for token-at-rest encryption
CRON_SECRET=                         # shared secret guarding scheduled endpoints

# ── [RUNTIME] Email (Resend) ─────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=Nova <noreply@nova.build>

# ── [RUNTIME] Billing (PayOS + LemonSqueezy) ─────────────────────────────────
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_CLIENT_ID=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_PRO=
LEMONSQUEEZY_VARIANT_TEAM=
LEMONSQUEEZY_WEBHOOK_SECRET=

# ── [RUNTIME] Observability ──────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info

# ── [RUNTIME] Storage — R2 (Cloudflare) ──────────────────────────────────────
# Original asset storage backend. Still used as fallback when ImageKit is not configured.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
NEXT_PUBLIC_ASSET_BASE_URL=          # R2 public bucket base URL (canvas assets)

# ── [RUNTIME] Storage — ImageKit (preferred) ─────────────────────────────────
# Sign up free at https://imagekit.io — 20 GB free bandwidth/month.
# When all three vars are set, uploads go to ImageKit instead of R2.
# Dashboard → Developer → API Keys
IMAGEKIT_PUBLIC_KEY=                 # public_xxxxxxxxxxxxxxxxxxxxxxx
IMAGEKIT_PRIVATE_KEY=                # private_xxxxxxxxxxxxxxxxxxxxxx  (server-only, never expose)
IMAGEKIT_URL_ENDPOINT=               # https://ik.imagekit.io/your_imagekit_id
