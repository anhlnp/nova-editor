# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# GitHub OAuth — create at github.com/settings/developers
# Name: "Nova Studio (Local)" | Callback: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── AI Provider (ADR-011) ───────────────────────────────────────────────────
# Select which AI provider to use as the server default.
# Users can also override this per-session in the editor UI.
# Options: anthropic | openai | google | groq | openrouter | mistral
# Pre-revenue recommendation: groq (fastest free) or google (most generous free quota)
AI_PROVIDER=groq

# ── Paid providers ──────────────────────────────────────────────────────────
# Anthropic Claude — https://console.anthropic.com/
# Planner: claude-haiku-4-5-20251001 | Patcher: claude-sonnet-4-6
ANTHROPIC_API_KEY=

# OpenAI GPT — https://platform.openai.com/api-keys
# Planner: gpt-4o-mini | Patcher: gpt-4o
OPENAI_API_KEY=

# ── Free tier providers (recommended for dev/testing) ───────────────────────
# Google Gemini — https://aistudio.google.com/app/apikey  (FREE, no CC)
# Planner: gemini-2.5-flash | Patcher: gemini-2.5-pro
# Free quota: 1,000 req/day, 15 req/min
GOOGLE_GENERATIVE_AI_API_KEY=

# Groq LPU — https://console.groq.com/keys  (FREE, no CC, fastest inference)
# Planner: llama-3.1-8b-instant | Patcher: llama-3.3-70b-versatile
# Free quota: 14,400 req/day, 30 req/min
GROQ_API_KEY=

# OpenRouter — https://openrouter.ai/keys  (FREE models have :free suffix)
# Planner: meta-llama/llama-3.1-8b-instruct:free | Patcher: google/gemma-3-27b-it:free
# Free quota: varies per model, may queue — good for model comparisons
OPENROUTER_API_KEY=

# Mistral AI — https://console.mistral.ai/api-keys  (open models are FREE)
# Planner: open-mistral-7b | Patcher: open-mixtral-8x7b
# Free quota: rate-limited, no billing required for open-weight models
MISTRAL_API_KEY=
# ───────────────────────────────────────────────────────────────────────────

# Supabase — server-side only, never expose to browser
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Payments
LEMONSQUEEZY_WEBHOOK_SECRET=
# Public checkout URL for the Free → Pro upgrade button (Lemon Squeezy hosted checkout).
# The app appends checkout[custom][github_id] so the webhook can match the buyer.
NEXT_PUBLIC_LEMONSQUEEZY_CHECKOUT_URL=

# Encryption key for storing GitHub/Vercel tokens in Supabase (32-char hex)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Cron security
CRON_SECRET=

# Observability (W7) — optional. If set, wire up @sentry/nextjs (not bundled by
# default). IP-level rate limiting on /api/ai is handled by src/middleware.ts.
SENTRY_DSN=

# Feature flags
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_MAX_FREE_CREDITS=20
